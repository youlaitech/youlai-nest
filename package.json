{
  "name": "youlai-nest",
  "version": "2.0.1",
  "description": "🌈 基于 Node.js、NestJS、TypeORM、Vite 构建的企业级权限管理后端，是 vue3-element-admin 配套的官方 Node.js 实现。",
  "author": "youlaitech",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.17.0",
    "pnpm": ">=8.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start:dev": "nest start",
    "start:prod": "node dist/main",
    "start:debug": "nest start --debug",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:config": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint --print-config src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@alicloud/ocr-api20210707": "^3.1.3",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.11",
    "@liaoliaots/nestjs-redis": "^10.0.0",
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/typeorm": "^11.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/ws": "^8.18.1",
    "ali-oss": "^6.23.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dayjs": "^1.11.19",
    "dotenv": "^16.6.1",
    "express-session": "^1.18.2",
    "install": "^0.13.0",
    "ioredis": "^5.9.1",
    "jszip": "^3.10.1",
    "minio": "^8.0.6",
    "multer": "1.4.5-lts.2",
    "mysql2": "^3.16.0",
    "nest-winston": "^1.10.2",
    "npm": "^11.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "svg-captcha": "^1.4.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.1",
    "velocityjs": "^2.1.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "xmcommon": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.11",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.29",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
