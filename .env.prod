# =========================
# 应用基础配置
# =========================

# 运行环境：dev / prod / test
NODE_ENV=dev

# Nest 应用监听端口（统一后端端口：8000）
APP_PORT=8000

# 会话类型：jwt | redis-token
SESSION_TYPE=jwt


# =========================
# MySQL 数据库配置（TypeORM）
# =========================

MYSQL_HOST=www.youlai.tech
MYSQL_PORT=3306
MYSQL_USER=youlai
MYSQL_PASSWORD=123456
MYSQL_DB=youlai_boot

# TypeORM SQL 日志输出
# - 开发环境：true（方便排查 SQL）
# - 生产环境：false（避免日志过大）
TYPEORM_LOGGING=true


# =========================
# Redis 配置
# =========================
# 用于缓存、会话、验证码等

REDIS_HOST=www.youlai.tech
REDIS_PORT=6379
REDIS_DB=7
# 无密码可以留空
REDIS_PASSWORD=123456


# =========================
# JWT 认证配置
# =========================
# 对应 src/config/jwt.config.ts 中的 JWT_SECRET_KEY / JWT_EXPIRES_IN / JWT_ISSUER

# =========================
# AI 配置（OpenAI-compatible）
# =========================

AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_API_KEY=sk-c2941d05bf2f411ca80424fcd1exxxxx
AI_MODEL=qwen-plus
AI_TIMEOUT_MS=20000

# 签名密钥（生产环境请使用复杂随机串）
JWT_SECRET_KEY=dev-jwt-secret-change-me

# 访问 Token 过期时间（单位：秒，例如 7200 表示 2 小时）
JWT_EXPIRES_IN=7200

# Token 签发方标识，用于区分不同系统
JWT_ISSUER=youlai-nest


# =========================
# OSS / 文件存储（MinIO / 阿里云 / 本地）
# =========================

# OSS 类型：aliyun | minio | local
OSS_TYPE=minio

# MinIO 对象存储服务
OSS_MINIO_ENDPOINT=http://localhost:9000
OSS_MINIO_ACCESS_KEY=minioadmin
OSS_MINIO_SECRET_KEY=minioadmin
OSS_MINIO_BUCKET=default
# 可选：自定义域名，配置后文件 URL 会使用该域名
OSS_MINIO_CUSTOM_DOMAIN=

# 阿里云 OSS 对象存储服务
OSS_ALIYUN_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ALIYUN_ACCESS_KEY_ID=your-access-key-id
OSS_ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ALIYUN_BUCKET=default

# 本地存储路径（仅在 OSS_TYPE=local 时生效）
OSS_LOCAL_STORAGE_PATH=D:/data/oss/
